{
  "objective": {
    "name": "production_objective_wad",
    "direction": "minimize",
    "description": "Lower is better for this production-oriented fee-policy benchmark: fee shortfall under an economically executable ceiling, plus overshoot and width-admission penalties.",
    "primary_metric": "production_objective_wad"
  },
  "editable_artifacts": [
    "src/OracleAnchoredLVRHook.sol"
  ],
  "context_files": [
    "foundry.toml",
    "src/OracleAnchoredLVRHook.sol",
    "src/oracles/ChainlinkReferenceOracle.sol",
    "test/OracleAnchoredLVRHook.t.sol",
    "test/OracleAnchoredLVRHookFuzz.t.sol",
    "test/OracleAnchoredLVRHookInvariants.t.sol",
    "test/OracleAnchoredLVRHookProperties.t.sol",
    "test/helpers/ManualAggregatorV3.sol",
    "script/lvr_validation.py",
    "script/lvr_validation_runner.py"
  ],
  "forbidden_paths": [
    "broadcast",
    "cache",
    "lib",
    "out",
    "script",
    "test",
    "toolchain"
  ],
  "support_files": [
    {
      "source": "support/OracleAnchoredLVRHookProductionEvaluator.t.sol",
      "destination": "test/harness/OracleAnchoredLVRHookProductionEvaluator.t.sol",
      "context": true
    }
  ],
  "validation_commands": [
    [
      "forge",
      "build"
    ],
    [
      "forge",
      "test",
      "--match-path",
      "test/ChainlinkReferenceOracle.t.sol"
    ],
    [
      "forge",
      "test",
      "--match-path",
      "test/OracleAnchoredLVRHook.t.sol"
    ],
    [
      "forge",
      "test",
      "--match-path",
      "test/OracleAnchoredLVRHookProperties.t.sol"
    ],
    [
      "forge",
      "test",
      "--match-path",
      "test/OracleAnchoredLVRHookFuzz.t.sol"
    ]
  ],
  "benchmark_command": [
    "forge",
    "test",
    "--match-path",
    "test/harness/OracleAnchoredLVRHookProductionEvaluator.t.sol",
    "--match-test",
    "test_writesHarnessMetrics"
  ],
  "benchmark_output_path": ".harness/foundry_hook/metrics.json",
  "required_metrics": [
    "production_objective_wad",
    "production_shortfall_wad",
    "fee_overshoot_penalty_wad",
    "width_penalty_wad",
    "realized_fee_revenue_wad",
    "economic_execution_rate_bps",
    "admission_rate_bps",
    "mean_required_width_ticks",
    "cap_hit_rate_bps"
  ],
  "repo_required_paths": [
    "foundry.toml",
    "src/OracleAnchoredLVRHook.sol",
    "src/oracles/ChainlinkReferenceOracle.sol",
    "test/OracleAnchoredLVRHook.t.sol",
    "test/OracleAnchoredLVRHookFuzz.t.sol",
    "test/OracleAnchoredLVRHookInvariants.t.sol",
    "test/OracleAnchoredLVRHookProperties.t.sol",
    "test/helpers/ManualAggregatorV3.sol",
    "script/lvr_validation.py",
    "script/lvr_validation_runner.py"
  ],
  "requires_gpu": false
}
